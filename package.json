{
  "name": "uclusion_node_sdk",
  "description": "SDK for the uclusion idea market system. All methods are supported, and each method closely corresponds the given api endpoints",
  "keywords": [
    "uclusion"
  ],
  "version": "0.0.1",
  "type": "module",
  "main": "src/uclusion.js",
  "dependencies": {
    "abort-controller": "^3.0.0",
    "amazon-cognito-identity-js": "^2.0.11",
    "aws-amplify": "^2.2.2",
    "jwt-decode": "^2.2.0",
    "lodash": "^4.17.15",
    "node-fetch": "^2.3.0",
    "stripe": "^8.181.0",
    "uclusion_sdk": "https://github.com/Uclusion/uclusion_sdk.git",
    "websocket": "^1.0.29"
  },
  "devDependencies": {
    "aws-sdk": "2.518.0",
    "mocha": "^11.0.0",
    "mocha-junit-reporter": "^2.2.1",
    "nyc": "^17.1.0"
  },
  "scripts": {
    "postinstall": "node scripts/fix-uclusion-sdk.js",
    "test": "mocha --recursive test",
    "testIntegration": "mocha --recursive test testIntegration",
    "testStage": "mocha --recursive testStage",
    "testProduction": "mocha --recursive testProduction",
    "coverage": "nyc report --reporter=html --reporter=text --reporter=lcovonly --report-dir=test/coverage"
  }
}
